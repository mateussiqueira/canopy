{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "mlx-local": {
      "name": "MLX Local (Apple Silicon)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8081/v1"
      },
      "models": {
        "mlx-local/llama-3.2-3b": {
          "id": "mlx-community/Llama-3.2-3B-Instruct-4bit",
          "name": "Llama 3.2 3B (Local)",
          "limit": { "context": 8192, "output": 4096 },
          "cost": { "input": 0, "output": 0 }
        },
        "mlx-local/qwen-coder-14b": {
          "id": "mlx-community/Qwen2.5-Coder-14B-Instruct-4bit",
          "name": "Qwen Coder 14B (Local)",
          "limit": { "context": 32768, "output": 4096 },
          "cost": { "input": 0, "output": 0 }
        },
        "mlx-local/mistral-7b": {
          "id": "mlx-community/Mistral-7B-Instruct-v0.3-4bit",
          "name": "Mistral 7B (Local)",
          "limit": { "context": 32768, "output": 4096 },
          "cost": { "input": 0, "output": 0 }
        }
      }
    }
  },
  "model": "mlx-local/llama-3.2-3b",
  "references": {
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
      "description": "Use for Effect v4 and effect-smol implementation details",
    },
    "opencode-local": {
      "path": "~/.local/share/opencode",
      "description": "Contains opencode logs and data",
    },
  },
  "mcp": {},
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
